{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/yeyouyby/autoenvplus/main/schemas/runtime-provider-plugin.schema.json",
  "title": "AutoEnvPlus declarative runtime provider plugin",
  "description": "Schema 2 binds a data-only archive Provider to one exact language tool. It cannot declare DLLs, scripts, commands, registry writes, environment mutations, or output paths.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "displayName",
    "vendor",
    "homepage",
    "license",
    "languageToolId",
    "releases"
  ],
  "properties": {
    "schemaVersion": {
      "const": 2
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
      "maxLength": 64
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96
    },
    "vendor": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96
    },
    "homepage": {
      "$ref": "#/$defs/httpsUri"
    },
    "license": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "languageToolId": {
      "description": "Exact built-in language tool that owns this Provider. Only tools with a registered managed ZIP adapter are accepted.",
      "enum": [
        "cpython",
        "nodejs",
        "eclipse-temurin",
        "dotnet-sdk",
        "msvc-build-tools",
        "clang",
        "gcc",
        "cmake",
        "ninja"
      ]
    },
    "releases": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "$ref": "#/$defs/release"
      }
    }
  },
  "$defs": {
    "httpsUri": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://[^/?#@]+(?::[0-9]+)?(?:/[^?#]*)?/?$",
      "description": "Absolute HTTPS URI without user-info, query, or fragment. The Core parser remains authoritative."
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240,
      "pattern": "^(?![./\\\\])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$))(?!.*:)[^\\u0000-\\u001F]+$"
    },
    "windowsExecutableRelativePath": {
      "allOf": [
        {
          "$ref": "#/$defs/relativePath"
        },
        {
          "pattern": "\\.[eE][xX][eE]$"
        }
      ],
      "description": "Safe archive-relative path to the managed Windows .exe entry point. DLL, script, and command entry points are not permitted."
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "channels",
        "assets"
      ],
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 96
        },
        "channels": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._+-]*$",
            "maxLength": 48
          }
        },
        "releaseDate": {
          "type": "string",
          "format": "date"
        },
        "assets": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "$ref": "#/$defs/asset"
          }
        }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "architecture",
        "fileName",
        "downloadUri",
        "checksumSourceUri",
        "expectedExecutableRelativePath"
      ],
      "oneOf": [
        {
          "required": ["sha256"],
          "not": {
            "required": ["sha512"]
          }
        },
        {
          "required": ["sha512"],
          "not": {
            "required": ["sha256"]
          }
        }
      ],
      "properties": {
        "architecture": {
          "enum": ["x86", "x64", "arm64"]
        },
        "fileName": {
          "type": "string",
          "minLength": 5,
          "maxLength": 180,
          "pattern": "^[^/\\\\:]+\\.zip$"
        },
        "downloadUri": {
          "$ref": "#/$defs/httpsUri"
        },
        "checksumSourceUri": {
          "$ref": "#/$defs/httpsUri",
          "description": "Plugin-declared HTTPS reference for an independently published checksum page or manifest. Schema 1 does not fetch or parse this URI; it is not an AutoEnvPlus-verified manifest or signature."
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "sha512": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{128}$"
        },
        "archiveRoot": {
          "$ref": "#/$defs/relativePath"
        },
        "expectedExecutableRelativePath": {
          "$ref": "#/$defs/windowsExecutableRelativePath"
        }
      }
    }
  }
}
