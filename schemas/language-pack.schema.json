{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yeyouyby/autoenvplus/schemas/language-pack.schema.json",
  "title": "AutoEnvPlus data-only language pack schema 1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "displayName",
    "publisher",
    "homepage",
    "license",
    "languages",
    "tools"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "$ref": "#/$defs/id" },
    "displayName": { "$ref": "#/$defs/displayName" },
    "publisher": { "$ref": "#/$defs/displayName" },
    "homepage": { "$ref": "#/$defs/httpsUri" },
    "license": { "type": "string", "minLength": 1, "maxLength": 128 },
    "languages": {
      "type": "array",
      "maxItems": 64,
      "items": { "$ref": "#/$defs/language" }
    },
    "tools": {
      "type": "array",
      "maxItems": 256,
      "items": { "$ref": "#/$defs/tool" }
    }
  },
  "anyOf": [
    { "properties": { "languages": { "minItems": 1 } } },
    { "properties": { "tools": { "minItems": 1 } } }
  ],
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,62}[a-z0-9])?$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96
    },
    "httpsUri": {
      "type": "string",
      "format": "uri",
      "maxLength": 2048,
      "pattern": "^https://[^?#]+$"
    },
    "stringArray": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 64 }
    },
    "language": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "displayName",
        "aliases",
        "fileExtensions",
        "defaultEnabled",
        "homepage"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "displayName": { "$ref": "#/$defs/displayName" },
        "aliases": {
          "allOf": [
            { "$ref": "#/$defs/stringArray" },
            { "maxItems": 32 }
          ]
        },
        "fileExtensions": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 24,
            "pattern": "^\\.[A-Za-z0-9][A-Za-z0-9._+-]{0,22}$"
          }
        },
        "defaultEnabled": { "const": false },
        "homepage": { "$ref": "#/$defs/httpsUri" }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "discover",
        "install",
        "versionSwitch",
        "projectPin",
        "sessionActivation",
        "packageManagement",
        "virtualEnvironment",
        "cacheManagement",
        "mirrorConfiguration",
        "debug",
        "format",
        "lint"
      ],
      "properties": {
        "discover": { "type": "boolean" },
        "install": { "type": "boolean" },
        "versionSwitch": { "type": "boolean" },
        "projectPin": { "type": "boolean" },
        "sessionActivation": { "type": "boolean" },
        "packageManagement": { "type": "boolean" },
        "virtualEnvironment": { "type": "boolean" },
        "cacheManagement": { "type": "boolean" },
        "mirrorConfiguration": { "type": "boolean" },
        "debug": { "type": "boolean" },
        "format": { "type": "boolean" },
        "lint": { "type": "boolean" }
      }
    },
    "mirrorSlot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "displayName",
        "defaultEndpoint",
        "endpointKind",
        "purpose",
        "userOverridable"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "displayName": { "$ref": "#/$defs/displayName" },
        "defaultEndpoint": { "$ref": "#/$defs/httpsUri" },
        "endpointKind": {
          "enum": [
            "pypi",
            "npm",
            "nuget",
            "maven",
            "gradle",
            "go-proxy",
            "crates",
            "rubygems",
            "composer",
            "generic-download"
          ]
        },
        "purpose": { "type": "string", "minLength": 1, "maxLength": 256 },
        "userOverridable": { "type": "boolean" }
      }
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "displayName",
        "distributionKind",
        "managedInstallSupported",
        "mirrorSlots"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "displayName": { "$ref": "#/$defs/displayName" },
        "distributionKind": {
          "enum": ["managed-archive", "manual", "system", "winget", "external"]
        },
        "managedInstallSupported": { "type": "boolean" },
        "mirrorSlots": {
          "type": "array",
          "maxItems": 16,
          "items": { "$ref": "#/$defs/mirrorSlot" }
        }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "displayName",
        "vendor",
        "homepage",
        "license",
        "languageIds",
        "roles",
        "discoveryCommands",
        "windowsSupport",
        "capabilities",
        "providers"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "displayName": { "$ref": "#/$defs/displayName" },
        "vendor": { "$ref": "#/$defs/displayName" },
        "homepage": { "$ref": "#/$defs/httpsUri" },
        "license": { "type": "string", "minLength": 1, "maxLength": 128 },
        "languageIds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        },
        "roles": {
          "type": "array",
          "minItems": 1,
          "maxItems": 14,
          "uniqueItems": true,
          "items": {
            "enum": [
              "compiler",
              "interpreter",
              "runtime",
              "sdk",
              "package-manager",
              "build",
              "debugger",
              "formatter",
              "linter",
              "version-manager",
              "virtual-env",
              "repl",
              "language-server",
              "test-runner"
            ]
          }
        },
        "discoveryCommands": {
          "type": "array",
          "maxItems": 24,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]{0,63}$"
          }
        },
        "windowsSupport": { "enum": ["native", "wsl", "conditional", "unsupported"] },
        "capabilities": { "$ref": "#/$defs/capabilities" },
        "providers": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": { "$ref": "#/$defs/provider" }
        }
      }
    }
  }
}
