<Page
    x:Class="AutoEnvPlus.App.Pages.RuntimesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" Spacing="18">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="运行时" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="安装、发现和切换多版本 Python、Node.js 与 Java。"
                        TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal"
                    Spacing="8">
                    <ProgressRing
                        x:Name="OperationProgress"
                        Width="20"
                        Height="20"
                        IsActive="False" />
                    <Button
                        x:Name="CancelOperationButton"
                        Click="OnCancelOperationClicked"
                        IsEnabled="False"
                        ToolTipService.ToolTip="取消当前目录加载、下载或文件操作">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Cancel" />
                            <TextBlock Text="取消" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="RefreshButton"
                        Click="OnRefreshClicked"
                        ToolTipService.ToolTip="重新检测 PATH 和托管运行时">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Refresh" />
                            <TextBlock Text="刷新" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <InfoBar
                x:Name="ActionInfo"
                IsClosable="False"
                IsOpen="True"
                Message="Node.js 会验证 OpenPGP 签名清单；Java 下载后会验证包本体的 detached OpenPGP 签名；Python 当前验证 HTTPS 来源和 SHA-256。"
                Severity="Informational"
                Title="安全安装模式" />

            <StackPanel Spacing="12">
                <Border
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Python" />
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="数据分析、自动化和后端开发" />
                            <TextBlock x:Name="PythonStatus" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="正在检测 python…" TextWrapping="Wrap" />
                        </StackPanel>
                        <Button
                            x:Name="PythonInstallButton"
                            Grid.Column="2"
                            Click="OnInstallClicked"
                            Content="安装版本"
                            Tag="Python" />
                    </Grid>
                </Border>

                <Border
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Node.js" />
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="前端工具链与服务端 JavaScript" />
                            <TextBlock x:Name="NodeStatus" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="正在检测 node…" TextWrapping="Wrap" />
                        </StackPanel>
                        <Button
                            x:Name="NodeInstallButton"
                            Grid.Column="2"
                            Click="OnInstallClicked"
                            Content="安装版本"
                            Tag="NodeJs" />
                    </Grid>
                </Border>

                <Border
                    Padding="20"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Java" />
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="JDK、编译器和 JVM 工具" />
                            <TextBlock x:Name="JavaStatus" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="正在检测 java…" TextWrapping="Wrap" />
                        </StackPanel>
                        <Button
                            x:Name="JavaInstallButton"
                            Grid.Column="2"
                            Click="OnInstallClicked"
                            Content="安装 JDK 21"
                            Tag="Java" />
                    </Grid>
                </Border>
            </StackPanel>

            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="AutoEnvPlus 托管版本" />
            <ListView
                x:Name="ManagedRuntimeList"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="12,8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                <Border
                                    Padding="6,2"
                                    Background="{ThemeResource AccentFillColorSecondaryBrush}"
                                    CornerRadius="4"
                                    Visibility="{Binding DefaultBadgeVisibility}">
                                    <TextBlock FontSize="12" Text="全局默认" />
                                </Border>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding Id}" TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Grid.Column="2"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{Binding InstallRoot}"
                                TextTrimming="CharacterEllipsis"
                                ToolTipService.ToolTip="{Binding InstallRoot}" />
                            <StackPanel
                                Grid.Column="3"
                                Orientation="Horizontal"
                                Spacing="8">
                                <Button
                                    Click="OnSetGlobalClicked"
                                    Content="{Binding DefaultActionText}"
                                    IsEnabled="{Binding CanSetGlobal}"
                                    Tag="{Binding}" />
                                <Button
                                    Click="OnUninstallClicked"
                                    Content="卸载"
                                    Tag="{Binding}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </ScrollViewer>
</Page>
