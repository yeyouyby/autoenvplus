<Page
    x:Class="AutoEnvPlus.App.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <Grid
            x:Name="LayoutRoot"
            Padding="{StaticResource PagePadding}"
            RowSpacing="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup>
                    <VisualState x:Name="CompactLayout">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="0" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="OverviewSecondary.(Grid.Row)" Value="1" />
                            <Setter Target="OverviewSecondary.(Grid.Column)" Value="0" />
                            <Setter Target="OverviewSecondary.Margin" Value="0,16,0,0" />
                            <Setter Target="OverviewSecondaryColumn.Width" Value="0" />
                            <Setter Target="OverviewSecondaryRow.Height" Value="Auto" />
                            <Setter Target="DetailsSecondary.(Grid.Row)" Value="1" />
                            <Setter Target="DetailsSecondary.(Grid.Column)" Value="0" />
                            <Setter Target="DetailsSecondary.Margin" Value="0,16,0,0" />
                            <Setter Target="DetailsSecondaryColumn.Width" Value="0" />
                            <Setter Target="DetailsSecondaryRow.Height" Value="Auto" />
                            <Setter Target="QuickActionThirdColumn.Width" Value="0" />
                            <Setter Target="QuickActionFourthColumn.Width" Value="0" />
                            <Setter Target="QuickActionRow0.Height" Value="44" />
                            <Setter Target="QuickActionRow1.Height" Value="44" />
                            <Setter Target="QuickActionRow2.Height" Value="44" />
                            <Setter Target="QuickActionRow3.Height" Value="44" />
                            <Setter Target="QuickActionRow4.Height" Value="44" />
                            <Setter Target="NetworkDownloadSecondaryColumn.Width" Value="0" />
                            <Setter Target="NetworkDownloadActionsColumn.Width" Value="0" />
                            <Setter Target="NetworkDownloadSecondaryRow.Height" Value="Auto" />
                            <Setter Target="NetworkDownloadActionsRow.Height" Value="Auto" />
                            <Setter Target="NetworkDownloadPanel.(Grid.Row)" Value="1" />
                            <Setter Target="NetworkDownloadPanel.(Grid.Column)" Value="1" />
                            <Setter Target="NetworkDownloadPanel.Margin" Value="0,12,0,0" />
                            <Setter Target="NetworkDownloadActions.(Grid.Row)" Value="2" />
                            <Setter Target="NetworkDownloadActions.(Grid.Column)" Value="1" />
                            <Setter Target="NetworkDownloadActions.Margin" Value="0,12,0,0" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="WideLayout">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="1000" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="OverviewSecondary.(Grid.Row)" Value="0" />
                            <Setter Target="OverviewSecondary.(Grid.Column)" Value="1" />
                            <Setter Target="OverviewSecondary.Margin" Value="16,0,0,0" />
                            <Setter Target="OverviewSecondaryColumn.Width" Value="*" />
                            <Setter Target="OverviewSecondaryRow.Height" Value="0" />
                            <Setter Target="DetailsSecondary.(Grid.Row)" Value="0" />
                            <Setter Target="DetailsSecondary.(Grid.Column)" Value="1" />
                            <Setter Target="DetailsSecondary.Margin" Value="16,0,0,0" />
                            <Setter Target="DetailsSecondaryColumn.Width" Value="*" />
                            <Setter Target="DetailsSecondaryRow.Height" Value="0" />
                            <Setter Target="QuickActionThirdColumn.Width" Value="*" />
                            <Setter Target="QuickActionFourthColumn.Width" Value="*" />
                            <Setter Target="RuntimeQuickAction.(Grid.Row)" Value="0" />
                            <Setter Target="RuntimeQuickAction.(Grid.Column)" Value="0" />
                            <Setter Target="ProjectsQuickAction.(Grid.Row)" Value="0" />
                            <Setter Target="ProjectsQuickAction.(Grid.Column)" Value="1" />
                            <Setter Target="NetworkQuickAction.(Grid.Row)" Value="0" />
                            <Setter Target="NetworkQuickAction.(Grid.Column)" Value="2" />
                            <Setter Target="DownloadsQuickAction.(Grid.Row)" Value="0" />
                            <Setter Target="DownloadsQuickAction.(Grid.Column)" Value="3" />
                            <Setter Target="PathQuickAction.(Grid.Row)" Value="1" />
                            <Setter Target="PathQuickAction.(Grid.Column)" Value="0" />
                            <Setter Target="StorageQuickAction.(Grid.Row)" Value="1" />
                            <Setter Target="StorageQuickAction.(Grid.Column)" Value="1" />
                            <Setter Target="DoctorQuickAction.(Grid.Row)" Value="1" />
                            <Setter Target="DoctorQuickAction.(Grid.Column)" Value="2" />
                            <Setter Target="ActivityQuickAction.(Grid.Row)" Value="1" />
                            <Setter Target="ActivityQuickAction.(Grid.Column)" Value="3" />
                            <Setter Target="PluginsQuickAction.(Grid.Row)" Value="2" />
                            <Setter Target="PluginsQuickAction.(Grid.Column)" Value="0" />
                            <Setter Target="QuickActionRow0.Height" Value="44" />
                            <Setter Target="QuickActionRow1.Height" Value="44" />
                            <Setter Target="QuickActionRow2.Height" Value="44" />
                            <Setter Target="QuickActionRow3.Height" Value="0" />
                            <Setter Target="QuickActionRow4.Height" Value="0" />
                            <Setter Target="NetworkDownloadSecondaryColumn.Width" Value="*" />
                            <Setter Target="NetworkDownloadActionsColumn.Width" Value="Auto" />
                            <Setter Target="NetworkDownloadSecondaryRow.Height" Value="0" />
                            <Setter Target="NetworkDownloadActionsRow.Height" Value="0" />
                            <Setter Target="NetworkDownloadPanel.(Grid.Row)" Value="0" />
                            <Setter Target="NetworkDownloadPanel.(Grid.Column)" Value="2" />
                            <Setter Target="NetworkDownloadPanel.Margin" Value="0" />
                            <Setter Target="NetworkDownloadActions.(Grid.Row)" Value="0" />
                            <Setter Target="NetworkDownloadActions.(Grid.Column)" Value="3" />
                            <Setter Target="NetworkDownloadActions.Margin" Value="0" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="概览" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="语言工具、项目环境、命令路由、下载和存储状态"
                        TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="10">
                    <ProgressRing
                        x:Name="RefreshProgress"
                        Width="20"
                        Height="20"
                        IsActive="False" />
                    <Button
                        x:Name="QuickRefreshButton"
                        Width="40"
                        Height="40"
                        AutomationProperties.Name="快速刷新概览"
                        Click="OnQuickRefreshClicked"
                        ToolTipService.ToolTip="只读取 AutoEnvPlus 受管状态">
                        <FontIcon FontSize="16" Glyph="&#xE72C;" />
                    </Button>
                    <Button
                        x:Name="FullScanButton"
                        Width="40"
                        Height="40"
                        AutomationProperties.Name="完整扫描环境"
                        Click="OnFullScanClicked"
                        ToolTipService.ToolTip="检查 PATH、命令版本和缓存体积">
                        <FontIcon FontSize="16" Glyph="&#xE721;" />
                    </Button>
                </StackPanel>
            </Grid>

            <InfoBar
                x:Name="OverviewInfo"
                Grid.Row="1"
                IsClosable="False"
                IsOpen="True"
                Severity="Informational"
                Title="正在载入概览快照" />

            <Grid Grid.Row="2" ColumnSpacing="8" RowSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition x:Name="QuickActionThirdColumn" Width="0" />
                    <ColumnDefinition x:Name="QuickActionFourthColumn" Width="0" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="QuickActionRow0" Height="44" />
                    <RowDefinition x:Name="QuickActionRow1" Height="44" />
                    <RowDefinition x:Name="QuickActionRow2" Height="44" />
                    <RowDefinition x:Name="QuickActionRow3" Height="44" />
                    <RowDefinition x:Name="QuickActionRow4" Height="44" />
                </Grid.RowDefinitions>
                <Button
                    x:Name="RuntimeQuickAction"
                    AutomationProperties.Name="管理语言工具"
                    Click="OnNavigateClicked"
                    HorizontalAlignment="Stretch"
                    Tag="languages">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE950;" />
                        <TextBlock Text="语言工具" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="ProjectsQuickAction"
                    Grid.Column="1"
                    AutomationProperties.Name="打开项目环境"
                    Click="OnNavigateClicked"
                    HorizontalAlignment="Stretch"
                    Tag="projects">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8B7;" />
                        <TextBlock Text="项目环境" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="NetworkQuickAction"
                    Grid.Row="1"
                    AutomationProperties.Name="配置命令版本"
                    Click="OnNavigateClicked"
                    HorizontalAlignment="Stretch"
                    Tag="path">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8A5;" />
                        <TextBlock Text="命令版本" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="DownloadsQuickAction"
                    Grid.Row="1"
                    Grid.Column="1"
                    AutomationProperties.Name="打开下载中心"
                    Click="OnNavigateClicked"
                    HorizontalAlignment="Stretch"
                    Tag="downloads">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE896;" />
                        <TextBlock Text="下载中心" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="PathQuickAction"
                    Grid.Row="2"
                    AutomationProperties.Name="检查 PATH"
                    Click="OnNavigateClicked"
                    HorizontalAlignment="Stretch"
                    Tag="path">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8A5;" />
                        <TextBlock Text="检查 PATH" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="StorageQuickAction"
                    Grid.Row="2"
                    Grid.Column="1"
                    AutomationProperties.Name="管理缓存和存储"
                    Click="OnNavigateClicked"
                    HorizontalAlignment="Stretch"
                    Tag="storage">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xEDA2;" />
                        <TextBlock Text="缓存与存储" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="DoctorQuickAction"
                    Grid.Row="3"
                    AutomationProperties.Name="运行环境诊断"
                    Click="OnNavigateClicked"
                    HorizontalAlignment="Stretch"
                    Tag="doctor">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE9D9;" />
                        <TextBlock Text="环境诊断" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="ActivityQuickAction"
                    Grid.Row="3"
                    Grid.Column="1"
                    AutomationProperties.Name="查看活动记录"
                    Click="OnNavigateClicked"
                    HorizontalAlignment="Stretch"
                    Tag="activity">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE823;" />
                        <TextBlock Text="活动记录" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="PluginsQuickAction"
                    Grid.Row="4"
                    AutomationProperties.Name="管理语言包与 Provider"
                    Click="OnNavigateClicked"
                    HorizontalAlignment="Stretch"
                    Tag="languages">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE943;" />
                        <TextBlock Text="语言包与 Provider" />
                    </StackPanel>
                </Button>
            </Grid>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition x:Name="OverviewSecondaryColumn" Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="OverviewSecondaryRow" Height="0" />
                </Grid.RowDefinitions>

                <Border
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="语言工具状态" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="托管版本、全局选择与发现状态"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                AutomationProperties.Name="打开语言工具页面"
                                Click="OnNavigateClicked"
                                Tag="languages"
                                ToolTipService.ToolTip="打开语言工具页面">
                                <SymbolIcon Symbol="Forward" />
                            </Button>
                        </Grid>
                        <ListView
                            x:Name="RuntimeOverviewList"
                            Grid.Row="1"
                            IsItemClickEnabled="False"
                            SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="MinHeight" Value="44" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="0,7" ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Version}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Grid.Column="2"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{Binding Detail}"
                                            TextTrimming="CharacterEllipsis"
                                            ToolTipService.ToolTip="{Binding Detail}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <Border
                    x:Name="OverviewSecondary"
                    Grid.Column="1"
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="PATH 健康度" />
                        <Grid Grid.Row="1" ColumnSpacing="12" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="PathDirectoryCountText" FontSize="24" FontWeight="SemiBold" Text="—" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="PATH 目录" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="PathMissingCountText" FontSize="24" FontWeight="SemiBold" Text="—" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="失效目录" />
                            </StackPanel>
                            <StackPanel Grid.Row="1">
                                <TextBlock x:Name="PathDuplicateCountText" FontSize="24" FontWeight="SemiBold" Text="—" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="重复目录" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1">
                                <TextBlock x:Name="PathConflictCountText" FontSize="24" FontWeight="SemiBold" Text="—" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="命令冲突" />
                            </StackPanel>
                        </Grid>
                        <TextBlock
                            x:Name="PathDetailText"
                            Grid.Row="2"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="正在检查当前进程 PATH…"
                            TextWrapping="Wrap" />
                    </Grid>
                </Border>
            </Grid>

            <Border
                Grid.Row="4"
                Padding="18"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CardCornerRadius}">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon
                        VerticalAlignment="Center"
                        FontSize="26"
                        Glyph="&#xEDA2;" />
                    <StackPanel Grid.Column="1" Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="缓存与受管数据" />
                            <TextBlock
                                x:Name="StorageUsageText"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                FontWeight="SemiBold"
                                Text="正在统计…" />
                        </StackPanel>
                        <TextBlock
                            x:Name="StorageDetailText"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="ManagedRootText"
                            IsTextSelectionEnabled="True"
                            TextTrimming="CharacterEllipsis"
                            ToolTipService.ToolTip="{Binding Text, ElementName=ManagedRootText}" />
                    </StackPanel>
                    <Button
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="打开缓存与存储页面"
                        Click="OnNavigateClicked"
                        Tag="storage"
                        ToolTipService.ToolTip="打开缓存与存储页面">
                        <SymbolIcon Symbol="Forward" />
                    </Button>
                </Grid>
            </Border>

            <Border
                Grid.Row="5"
                Padding="18"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CardCornerRadius}">
                <Grid x:Name="NetworkDownloadLayout" ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition x:Name="NetworkDownloadSecondaryColumn" />
                        <ColumnDefinition x:Name="NetworkDownloadActionsColumn" Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="NetworkDownloadSecondaryRow" Height="0" />
                        <RowDefinition x:Name="NetworkDownloadActionsRow" Height="0" />
                    </Grid.RowDefinitions>
                    <FontIcon
                        VerticalAlignment="Center"
                        FontSize="26"
                        Glyph="&#xE774;" />
                    <StackPanel Grid.Column="1" Spacing="3">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="全局代理" />
                        <TextBlock
                            x:Name="NetworkProfileText"
                            FontWeight="SemiBold"
                            Text="正在读取…"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="NetworkDetailText"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel
                        x:Name="NetworkDownloadPanel"
                        Grid.Column="2"
                        Spacing="3">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="受管传输" />
                        <TextBlock
                            x:Name="DownloadLibraryText"
                            FontWeight="SemiBold"
                            Text="正在读取…"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="DownloadTransferText"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel
                        x:Name="NetworkDownloadActions"
                        Grid.Column="3"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            AutomationProperties.Name="打开代理设置"
                            Click="OnNavigateClicked"
                            Tag="settings"
                            ToolTipService.ToolTip="打开代理设置">
                            <FontIcon Glyph="&#xE774;" />
                        </Button>
                        <Button
                            AutomationProperties.Name="打开下载中心页面"
                            Click="OnNavigateClicked"
                            Tag="downloads"
                            ToolTipService.ToolTip="打开下载中心页面">
                            <FontIcon Glyph="&#xE896;" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border
                Grid.Row="6"
                Padding="18"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CardCornerRadius}">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon
                        VerticalAlignment="Center"
                        FontSize="26"
                        Glyph="&#xE943;" />
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="语言包与 Provider" />
                        <TextBlock
                            x:Name="PluginSummaryText"
                            FontWeight="SemiBold"
                            Text="正在读取…"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="PluginDetailText"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Provider 归属于语言工具，镜像槽随 Provider 一起配置。"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <Button
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="打开语言包与 Provider"
                        Click="OnNavigateClicked"
                        Tag="languages"
                        ToolTipService.ToolTip="打开语言包与 Provider">
                        <SymbolIcon Symbol="Forward" />
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition x:Name="DetailsSecondaryColumn" Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="DetailsSecondaryRow" Height="0" />
                </Grid.RowDefinitions>

                <Border
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}">
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="最近项目" />
                            <Button
                                Grid.Column="1"
                                AutomationProperties.Name="打开项目环境页面"
                                Click="OnNavigateClicked"
                                Tag="projects"
                                ToolTipService.ToolTip="打开项目环境页面">
                                <SymbolIcon Symbol="Forward" />
                            </Button>
                        </Grid>
                        <Grid Grid.Row="1" MinHeight="100">
                            <ListView
                                x:Name="RecentProjectsList"
                                IsItemClickEnabled="False"
                                SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Button
                                            AutomationProperties.Name="{Binding AutomationName}"
                                            Click="OnRecentProjectClicked"
                                            HorizontalContentAlignment="Stretch"
                                            IsEnabled="{Binding Exists}"
                                            Padding="8"
                                            Style="{StaticResource TextBlockButtonStyle}"
                                            Tag="{Binding}">
                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Text="{Binding ProjectRoot}"
                                                        TextTrimming="CharacterEllipsis"
                                                        ToolTipService.ToolTip="{Binding ProjectRoot}" />
                                                </StackPanel>
                                                <TextBlock
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="{Binding LastSeenText}" />
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <TextBlock
                                x:Name="ProjectsEmptyText"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="尚未记录项目。"
                                Visibility="Collapsed" />
                        </Grid>
                    </Grid>
                </Border>

                <Border
                    x:Name="DetailsSecondary"
                    Grid.Column="1"
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}">
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="最近活动" />
                            <Button
                                Grid.Column="1"
                                AutomationProperties.Name="打开活动记录页面"
                                Click="OnNavigateClicked"
                                Tag="activity"
                                ToolTipService.ToolTip="打开活动记录页面">
                                <SymbolIcon Symbol="Forward" />
                            </Button>
                        </Grid>
                        <Grid Grid.Row="1" MinHeight="100">
                            <ListView
                                x:Name="RecentActivityList"
                                IsItemClickEnabled="False"
                                SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="MinHeight" Value="44" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="0,7" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Operation}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                Text="{Binding Summary}"
                                                TextTrimming="CharacterEllipsis"
                                                ToolTipService.ToolTip="{Binding Summary}" />
                                            <TextBlock
                                                Grid.Column="2"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{Binding Timestamp}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <TextBlock
                                x:Name="ActivityEmptyText"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="暂无活动记录。"
                                Visibility="Collapsed" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
