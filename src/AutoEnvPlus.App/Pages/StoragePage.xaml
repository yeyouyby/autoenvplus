<Page
    x:Class="AutoEnvPlus.App.Pages.StoragePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="{StaticResource PagePadding}" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="缓存与存储" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="识别 pip、npm、pnpm、Yarn、NuGet、Maven、Gradle、vcpkg 和 Conan 的真实存储位置与配置来源。"
                    TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Bottom"
                Orientation="Horizontal"
                Spacing="8">
                <ProgressRing
                    x:Name="StorageOperationProgress"
                    Width="20"
                    Height="20"
                    IsActive="False" />
                <Button
                    x:Name="CancelStorageOperationButton"
                    Click="OnCancelStorageOperationClicked"
                    IsEnabled="False"
                    ToolTipService.ToolTip="取消当前存储操作">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Cancel" />
                        <TextBlock Text="取消当前操作" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="RollbackButton"
                    Click="OnRollbackClicked"
                    IsEnabled="False"
                    ToolTipService.ToolTip="恢复最近一次迁移前的工具配置">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Undo" />
                        <TextBlock Text="回滚最近配置" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="MeasureButton"
                    Click="OnMeasureClicked"
                    Content="计算全部大小" />
            </StackPanel>
        </Grid>

        <InfoBar
            x:Name="StorageInfo"
            Grid.Row="1"
            IsClosable="False"
            IsOpen="True"
            Message="迁移保留原目录；安全清理先移入同卷隔离区。Gradle 与 Conan 根目录包含配置，不提供整目录清理。"
            Severity="Informational"
            Title="已读取当前配置" />

        <Grid
            Grid.Row="2"
            Padding="12,8"
            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
            ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center" Orientation="Horizontal" Spacing="8">
                <TextBlock FontWeight="SemiBold" Text="安全隔离区" />
                <TextBlock
                    x:Name="CleanupItemCountText"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="无待处理项" />
            </StackPanel>
            <ComboBox
                x:Name="CleanupItemPicker"
                Grid.Column="1"
                MinWidth="320"
                HorizontalAlignment="Stretch"
                DisplayMemberPath="DisplayText"
                PlaceholderText="没有可恢复或清空的缓存"
                SelectionChanged="OnCleanupItemSelectionChanged" />
            <Button
                x:Name="RestoreCleanupButton"
                Grid.Column="2"
                Click="OnRestoreCleanupClicked"
                IsEnabled="False"
                ToolTipService.ToolTip="将隔离内容移回原缓存目录">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SymbolIcon Symbol="Undo" />
                    <TextBlock Text="恢复" />
                </StackPanel>
            </Button>
            <Button
                x:Name="PurgeCleanupButton"
                Grid.Column="3"
                Click="OnPurgeCleanupClicked"
                IsEnabled="False"
                ToolTipService.ToolTip="永久删除已复检的隔离内容">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SymbolIcon Symbol="Delete" />
                    <TextBlock Text="永久清空" />
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="3" Padding="12,8" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="210" />
            </Grid.ColumnDefinitions>
            <TextBlock FontWeight="SemiBold" Text="工具" />
            <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="目录" />
            <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="来源" />
            <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="大小" />
            <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="操作" />
        </Grid>

        <ListView
            x:Name="CacheList"
            Grid.Row="4"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="12,8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="210" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                        <TextBlock
                            Grid.Column="1"
                            Text="{Binding DirectoryPath}"
                            TextTrimming="CharacterEllipsis"
                            ToolTipService.ToolTip="{Binding DirectoryPath}" />
                        <TextBlock
                            Grid.Column="2"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding SourceText}"
                            TextTrimming="CharacterEllipsis"
                            ToolTipService.ToolTip="{Binding SourceText}" />
                        <TextBlock Grid.Column="3" Text="{Binding SizeText}" />
                        <StackPanel
                            Grid.Column="4"
                            Orientation="Horizontal"
                            Spacing="8">
                            <Button
                                Click="OnOpenFolderClicked"
                                Content="打开"
                                IsEnabled="{Binding CanOpen}"
                                Tag="{Binding}"
                                ToolTipService.ToolTip="在文件资源管理器中打开实际目录" />
                            <Button
                                Click="OnMigrateClicked"
                                Content="迁移"
                                IsEnabled="{Binding CanMigrate}"
                                Tag="{Binding}" />
                            <Button
                                Click="OnCleanupClicked"
                                IsEnabled="{Binding CanClean}"
                                Tag="{Binding}"
                                ToolTipService.ToolTip="{Binding CleanupToolTip}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <SymbolIcon Symbol="Delete" />
                                    <TextBlock Text="清理" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
