<Page
    x:Class="AutoEnvPlus.App.Pages.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="{StaticResource PagePadding}" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="环境诊断" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="解释 PATH、命令来源、版本探测、托管状态和全局选择。"
                    TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Bottom"
                Orientation="Horizontal"
                Spacing="8">
                <ProgressRing
                    x:Name="DiagnosticProgress"
                    Width="20"
                    Height="20"
                    IsActive="False" />
                <Button
                    x:Name="ExportButton"
                    Click="OnExportClicked"
                    IsEnabled="False"
                    ToolTipService.ToolTip="将当前诊断保存为结构化 JSON">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Save" />
                        <TextBlock Text="导出 JSON" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="CancelButton"
                    Click="OnCancelClicked"
                    IsEnabled="False"
                    ToolTipService.ToolTip="取消版本探测">
                    <SymbolIcon Symbol="Cancel" />
                </Button>
                <Button
                    x:Name="RefreshButton"
                    Click="OnRefreshClicked"
                    ToolTipService.ToolTip="重新执行只读诊断">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Refresh" />
                        <TextBlock Text="重新扫描" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <InfoBar
            x:Name="SummaryInfo"
            Grid.Row="1"
            IsClosable="False"
            IsOpen="True"
            Message="正在读取当前环境；诊断不会修改 PATH、配置或运行时。"
            Severity="Informational"
            Title="准备扫描" />

        <Pivot Grid.Row="2">
            <PivotItem Header="问题">
                <ListView x:Name="IssueList" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,10" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="230" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Foreground="{Binding SeverityBrush}"
                                    Text="{Binding Severity}" />
                                <TextBlock
                                    Grid.Column="1"
                                    FontWeight="SemiBold"
                                    Text="{Binding Title}"
                                    TextWrapping="Wrap" />
                                <StackPanel Grid.Column="2" Spacing="3">
                                    <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        IsTextSelectionEnabled="True"
                                        Text="{Binding Path}"
                                        TextWrapping="WrapWholeWords"
                                        Visibility="{Binding PathVisibility}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </PivotItem>

            <PivotItem Header="命令来源">
                <ListView x:Name="CommandList" SelectionMode="None">
                    <ListView.Header>
                        <Grid Padding="12,8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontWeight="SemiBold" Text="命令" />
                            <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="实际入口" />
                            <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="候选" />
                        </Grid>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontWeight="SemiBold" Text="{Binding Command}" />
                                <TextBlock
                                    Grid.Column="1"
                                    IsTextSelectionEnabled="True"
                                    Text="{Binding Winner}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTipService.ToolTip="{Binding Winner}" />
                                <TextBlock Grid.Column="2" Text="{Binding CandidateText}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </PivotItem>

            <PivotItem Header="运行时与选择">
                <Grid RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="Auto" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <ListView x:Name="RuntimeList" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="12,8" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Runtime}" />
                                    <TextBlock Grid.Column="1" Text="{Binding Version}" />
                                    <TextBlock
                                        Grid.Column="2"
                                        IsTextSelectionEnabled="True"
                                        Text="{Binding Path}"
                                        TextTrimming="CharacterEllipsis"
                                        ToolTipService.ToolTip="{Binding Path}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock
                        Grid.Row="1"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Text="全局选择解析" />
                    <ListView Grid.Row="2" x:Name="GlobalSelectionList" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="12,8" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Runtime}" />
                                    <TextBlock Grid.Column="1" Text="{Binding Selector}" />
                                    <TextBlock Grid.Column="2" Text="{Binding Resolution}" TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
