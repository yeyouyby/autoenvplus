<Page
    x:Class="AutoEnvPlus.App.Pages.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="{StaticResource PagePadding}" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="环境诊断" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="选择需要的扫描域；只读取真实状态，项目、缓存和联网检查不会自动运行。"
                    TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Bottom"
                Orientation="Horizontal"
                Spacing="8">
                <ProgressRing
                    x:Name="DiagnosticProgress"
                    Width="20"
                    Height="20"
                    IsActive="False" />
                <Button
                    x:Name="ExportButton"
                    Click="OnExportClicked"
                    IsEnabled="False"
                    ToolTipService.ToolTip="导出当前结构化诊断报告">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Save" />
                        <TextBlock Text="导出 JSON" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="CancelButton"
                    Width="36"
                    Height="36"
                    AutomationProperties.Name="取消诊断"
                    Click="OnCancelClicked"
                    IsEnabled="False"
                    ToolTipService.ToolTip="取消当前诊断">
                    <SymbolIcon Symbol="Cancel" />
                </Button>
                <Button
                    x:Name="RefreshButton"
                    Click="OnRefreshClicked"
                    ToolTipService.ToolTip="按所选范围执行只读诊断">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Play" />
                        <TextBlock Text="开始扫描" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Expander
            x:Name="ScopeExpander"
            Grid.Row="1"
            Header="扫描范围"
            IsExpanded="True">
            <Grid Padding="0,8,0,4" ColumnSpacing="20" RowSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <CheckBox
                    x:Name="PathScopeCheckBox"
                    Click="OnScopeSelectionChanged"
                    Content="PATH、命令与 Shim"
                    IsChecked="True" />
                <CheckBox
                    x:Name="ManagedScopeCheckBox"
                    Grid.Column="1"
                    Click="OnScopeSelectionChanged"
                    Content="托管语言工具与版本选择"
                    IsChecked="True" />
                <CheckBox
                    x:Name="ProviderScopeCheckBox"
                    Grid.Row="1"
                    Click="OnScopeSelectionChanged"
                    Content="Provider 与来源配置"
                    IsChecked="True" />
                <CheckBox
                    x:Name="ProjectScopeCheckBox"
                    Grid.Row="1"
                    Grid.Column="1"
                    Click="OnProjectScopeChanged"
                    Content="项目选择与虚拟环境" />
                <CheckBox
                    x:Name="StorageScopeCheckBox"
                    Grid.Row="2"
                    Click="OnScopeSelectionChanged"
                    Content="缓存、暂存与磁盘（较慢）" />
                <CheckBox
                    x:Name="ConnectivityScopeCheckBox"
                    Grid.Row="2"
                    Grid.Column="1"
                    Click="OnScopeSelectionChanged"
                    Content="Provider 来源实时连接（较慢）" />

                <Grid
                    Grid.Row="3"
                    Grid.ColumnSpan="2"
                    ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="ProjectPathTextBox"
                        AutomationProperties.Name="诊断项目目录"
                        IsEnabled="False"
                        IsReadOnly="True"
                        PlaceholderText="选择项目目录" />
                    <Button
                        x:Name="BrowseProjectButton"
                        Grid.Column="1"
                        Height="36"
                        AutomationProperties.Name="选择诊断项目目录"
                        Click="OnBrowseProjectClicked"
                        IsEnabled="False"
                        ToolTipService.ToolTip="选择项目目录">
                        <FontIcon FontSize="14" Glyph="&#xE8B7;" />
                    </Button>
                </Grid>

                <TextBlock
                    x:Name="ScopeHintText"
                    Grid.Row="4"
                    Grid.ColumnSpan="2"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="已选择 3 个扫描域；不会遍历项目、缓存或访问网络。"
                    TextWrapping="Wrap" />
            </Grid>
        </Expander>

        <InfoBar
            x:Name="SummaryInfo"
            Grid.Row="2"
            IsClosable="False"
            IsOpen="True"
            Message="选择范围后开始扫描；所有检查均为只读。"
            Severity="Informational"
            Title="等待扫描" />

        <Pivot Grid.Row="3">
            <PivotItem Header="扫描摘要">
                <ListView x:Name="ScopeList" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,9" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontWeight="SemiBold" Text="{Binding Scope}" />
                                <TextBlock Grid.Column="1" Text="{Binding Result}" />
                                <TextBlock
                                    Grid.Column="2"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{Binding Detail}"
                                    TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </PivotItem>

            <PivotItem Header="问题">
                <ListView x:Name="IssueList" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,10" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="{Binding Scope}"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Grid.Column="1"
                                    FontWeight="SemiBold"
                                    Foreground="{Binding SeverityBrush}"
                                    Text="{Binding Severity}" />
                                <StackPanel Grid.Column="2" Spacing="3">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="{Binding Title}"
                                        TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        IsTextSelectionEnabled="True"
                                        Text="{Binding Path}"
                                        TextWrapping="WrapWholeWords"
                                        Visibility="{Binding PathVisibility}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </PivotItem>

            <PivotItem Header="命令路由">
                <ListView x:Name="CommandList" SelectionMode="None">
                    <ListView.Header>
                        <Grid Padding="12,8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontWeight="SemiBold" Text="命令" />
                            <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="实际入口" />
                            <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="候选" />
                        </Grid>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontWeight="SemiBold" Text="{Binding Command}" />
                                <TextBlock
                                    Grid.Column="1"
                                    IsTextSelectionEnabled="True"
                                    Text="{Binding Winner}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTipService.ToolTip="{Binding Winner}" />
                                <TextBlock Grid.Column="2" Text="{Binding CandidateText}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </PivotItem>

            <PivotItem Header="语言工具与选择">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="Auto" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <ListView x:Name="RuntimeList" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="12,8" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Runtime}" />
                                    <TextBlock Grid.Column="1" Text="{Binding Version}" />
                                    <TextBlock
                                        Grid.Column="2"
                                        IsTextSelectionEnabled="True"
                                        Text="{Binding Path}"
                                        TextTrimming="CharacterEllipsis"
                                        ToolTipService.ToolTip="{Binding Path}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock
                        Grid.Row="1"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Text="全局选择解析" />
                    <ListView Grid.Row="2" x:Name="GlobalSelectionList" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="12,8" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Runtime}" />
                                    <TextBlock Grid.Column="1" Text="{Binding Selector}" />
                                    <TextBlock
                                        Grid.Column="2"
                                        Text="{Binding Resolution}"
                                        TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
