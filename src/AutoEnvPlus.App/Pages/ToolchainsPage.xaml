<Page
    x:Class="AutoEnvPlus.App.Pages.ToolchainsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" Spacing="18">
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="C/C++ 工具链" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="组合 Visual Studio、MSVC、Windows SDK、LLVM、MinGW/GCC、CMake、Ninja 和目标架构。"
                    TextWrapping="Wrap" />
            </StackPanel>

            <InfoBar
                x:Name="ToolchainInfo"
                IsClosable="False"
                IsOpen="True"
                Message="正在读取 vswhere、Windows Kits 和 PATH…"
                Severity="Informational"
                Title="检测工具链" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Click="OnInstallComponentClicked" Content="安装/修复 MSVC" Tag="MsvcBuildTools" />
                <Button Click="OnInstallComponentClicked" Content="安装 LLVM" Tag="Llvm" />
                <Button Click="OnInstallComponentClicked" Content="安装 MinGW / GCC" Tag="MinGw" />
                <Button Click="OnInstallComponentClicked" Content="安装 CMake" Tag="CMake" />
                <Button Click="OnInstallComponentClicked" Content="安装 Ninja" Tag="Ninja" />
            </StackPanel>

            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Visual C++" />
            <StackPanel x:Name="VisualStudioPanel" Spacing="10" />

            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Windows SDK" />
            <StackPanel x:Name="SdkPanel" Spacing="10" />

            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="独立构建工具" />
            <StackPanel x:Name="BuildToolsPanel" Spacing="10" />
        </StackPanel>
    </ScrollViewer>
</Page>
