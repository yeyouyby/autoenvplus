<Page
    x:Class="AutoEnvPlus.App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" Spacing="20">
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="设置" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Shell 集成、下载源与应用行为"
                    TextWrapping="Wrap" />
            </StackPanel>

            <Border
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,1"
                Padding="0,18">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="40"
                        Height="40"
                        Background="{ThemeResource AccentFillColorSecondaryBrush}"
                        CornerRadius="8">
                        <FontIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="18"
                            Glyph="&#xE790;" />
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="5">
                        <TextBlock
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="外观与无障碍" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="当前窗口背景" />
                        <TextBlock
                            x:Name="EffectiveBackdropText"
                            FontWeight="SemiBold"
                            IsTextSelectionEnabled="True" />
                        <TextBlock
                            x:Name="BackdropDescriptionText"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            IsTextSelectionEnabled="True"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,1"
                Padding="0,18">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="6">
                        <TextBlock
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="受管数据根" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="运行时、Shim、注册表、项目状态和诊断快照都保存在这里。不会自动迁移或删除旧目录。"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="ManagedRootText"
                            FontWeight="SemiBold"
                            IsTextSelectionEnabled="True"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            x:Name="ManagedRootDescriptionText"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            IsTextSelectionEnabled="True"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="1"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            x:Name="ChooseManagedRootButton"
                            Click="OnChooseManagedRootClicked"
                            ToolTipService.ToolTip="选择非系统盘上的受管数据目录">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="OpenFile" />
                                <TextBlock Text="选择数据根" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <InfoBar
                        x:Name="ManagedRootInfo"
                        Grid.Row="2"
                        IsClosable="False"
                        IsOpen="False" />
                </Grid>
            </Border>

            <Border
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,1"
                Padding="0,18">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="6">
                        <TextBlock
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="PowerShell 会话集成" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="当前用户 Profile"
                            TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="ProfilePathText"
                            IsTextSelectionEnabled="True"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="1"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            x:Name="PreviewPowerShellButton"
                            Click="OnPreviewPowerShellClicked"
                            ToolTipService.ToolTip="预览 Profile 与模块变更">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="View" />
                                <TextBlock Text="预览" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="InstallPowerShellButton"
                            Click="OnInstallPowerShellClicked"
                            Style="{StaticResource AccentButtonStyle}"
                            ToolTipService.ToolTip="确认后安装 PowerShell 集成">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Accept" />
                                <TextBlock Text="安装" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="RollbackPowerShellButton"
                            Click="OnRollbackPowerShellClicked"
                            IsEnabled="False"
                            ToolTipService.ToolTip="恢复本次安装前的 Profile 快照">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Undo" />
                                <TextBlock Text="回滚" />
                            </StackPanel>
                        </Button>
                        <ProgressRing
                            x:Name="PowerShellProgress"
                            Width="20"
                            Height="20"
                            IsActive="False" />
                    </StackPanel>
                </Grid>
            </Border>

            <InfoBar
                x:Name="PowerShellInfo"
                IsClosable="False"
                IsOpen="False" />

            <Pivot x:Name="PowerShellPreviewPivot" Visibility="Collapsed">
                <PivotItem Header="摘要">
                    <TextBox
                        x:Name="PowerShellSummaryText"
                        MinHeight="150"
                        MaxHeight="280"
                        AcceptsReturn="True"
                        FontFamily="Consolas"
                        IsReadOnly="True"
                        TextWrapping="Wrap" />
                </PivotItem>
                <PivotItem Header="Profile">
                    <TextBox
                        x:Name="PowerShellProfilePreviewText"
                        MinHeight="220"
                        MaxHeight="420"
                        AcceptsReturn="True"
                        FontFamily="Consolas"
                        IsReadOnly="True"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        TextWrapping="NoWrap"
                        />
                </PivotItem>
                <PivotItem Header="模块">
                    <TextBox
                        x:Name="PowerShellModulePreviewText"
                        MinHeight="220"
                        MaxHeight="420"
                        AcceptsReturn="True"
                        FontFamily="Consolas"
                        IsReadOnly="True"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        TextWrapping="NoWrap"
                        />
                </PivotItem>
            </Pivot>
        </StackPanel>
    </ScrollViewer>
</Page>
