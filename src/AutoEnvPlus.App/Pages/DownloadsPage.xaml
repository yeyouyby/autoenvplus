<Page
    x:Class="AutoEnvPlus.App.Pages.DownloadsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            x:Name="LayoutRoot"
            Padding="{StaticResource PagePadding}"
            Spacing="20">
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup>
                    <VisualState x:Name="CompactLayout">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="0" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="HeaderActions.(Grid.Row)" Value="1" />
                            <Setter Target="HeaderActions.(Grid.Column)" Value="0" />
                            <Setter Target="HeaderActions.Margin" Value="0,12,0,0" />

                            <Setter Target="DownloadPrimaryColumn.Width" Value="*" />
                            <Setter Target="DownloadConnectionColumn.Width" Value="0" />
                            <Setter Target="DownloadMaximumColumn.Width" Value="0" />
                            <Setter Target="DownloadConnectionRow.Height" Value="Auto" />
                            <Setter Target="DownloadMaximumRow.Height" Value="Auto" />
                            <Setter Target="ConnectionCountPicker.(Grid.Row)" Value="1" />
                            <Setter Target="ConnectionCountPicker.(Grid.Column)" Value="0" />
                            <Setter Target="MaximumSizeBox.(Grid.Row)" Value="2" />
                            <Setter Target="MaximumSizeBox.(Grid.Column)" Value="0" />

                            <Setter Target="IntegrityPrimaryColumn.Width" Value="*" />
                            <Setter Target="IntegritySecondaryColumn.Width" Value="0" />
                            <Setter Target="IntegrityHashRow.Height" Value="Auto" />
                            <Setter Target="ExpectedHashTextBox.(Grid.Row)" Value="1" />
                            <Setter Target="ExpectedHashTextBox.(Grid.Column)" Value="0" />

                            <Setter Target="TransferActions.Orientation" Value="Vertical" />
                            <Setter Target="TransferBytesColumn.Width" Value="0" />
                            <Setter Target="TransferBytesRow.Height" Value="Auto" />
                            <Setter Target="TransferBytesText.(Grid.Row)" Value="1" />
                            <Setter Target="TransferBytesText.(Grid.Column)" Value="0" />
                            <Setter Target="TransferBytesText.Margin" Value="0,4,0,0" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="WideLayout">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="760" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="HeaderActions.(Grid.Row)" Value="0" />
                            <Setter Target="HeaderActions.(Grid.Column)" Value="1" />
                            <Setter Target="HeaderActions.Margin" Value="12,0,0,0" />

                            <Setter Target="DownloadPrimaryColumn.Width" Value="*" />
                            <Setter Target="DownloadConnectionColumn.Width" Value="160" />
                            <Setter Target="DownloadMaximumColumn.Width" Value="180" />
                            <Setter Target="DownloadConnectionRow.Height" Value="0" />
                            <Setter Target="DownloadMaximumRow.Height" Value="0" />
                            <Setter Target="ConnectionCountPicker.(Grid.Row)" Value="0" />
                            <Setter Target="ConnectionCountPicker.(Grid.Column)" Value="1" />
                            <Setter Target="MaximumSizeBox.(Grid.Row)" Value="0" />
                            <Setter Target="MaximumSizeBox.(Grid.Column)" Value="2" />

                            <Setter Target="IntegrityPrimaryColumn.Width" Value="180" />
                            <Setter Target="IntegritySecondaryColumn.Width" Value="*" />
                            <Setter Target="IntegrityHashRow.Height" Value="0" />
                            <Setter Target="ExpectedHashTextBox.(Grid.Row)" Value="0" />
                            <Setter Target="ExpectedHashTextBox.(Grid.Column)" Value="1" />

                            <Setter Target="TransferActions.Orientation" Value="Horizontal" />
                            <Setter Target="TransferBytesColumn.Width" Value="Auto" />
                            <Setter Target="TransferBytesRow.Height" Value="0" />
                            <Setter Target="TransferBytesText.(Grid.Row)" Value="0" />
                            <Setter Target="TransferBytesText.(Grid.Column)" Value="1" />
                            <Setter Target="TransferBytesText.Margin" Value="0" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Spacing="4">
                    <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="下载中心" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="把直接 HTTPS 文件通过多连接分段下载或本地导入到受管库；文件不会自动执行。"
                        TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel
                    x:Name="HeaderActions"
                    Grid.Column="1"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        x:Name="ImportButton"
                        Click="OnImportClicked"
                        ToolTipService.ToolTip="复制本地包到受管下载库">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="OpenFile" />
                            <TextBlock Text="导入本地文件" />
                        </StackPanel>
                    </Button>
                    <Button
                        Click="OnOpenLibraryClicked"
                        ToolTipService.ToolTip="在文件资源管理器中打开受管下载库">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Folder" />
                            <TextBlock Text="打开下载库" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <InfoBar
                x:Name="DownloadInfo"
                IsClosable="False"
                IsOpen="True"
                Message="服务器不支持稳定的 HTTP Range 时会自动从零开始单连接下载；不会降低 HTTPS 或摘要校验要求。"
                Severity="Informational"
                Title="受管传输" />

            <StackPanel Spacing="12">
                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="从 URL 添加" />
                <TextBox
                    x:Name="SourceUrlTextBox"
                    Header="HTTPS 文件地址"
                    PlaceholderText="https://download.example/package.whl"
                    TextChanged="OnSourceUrlChanged" />
                <Grid ColumnSpacing="12" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="DownloadPrimaryColumn" />
                        <ColumnDefinition x:Name="DownloadConnectionColumn" Width="160" />
                        <ColumnDefinition x:Name="DownloadMaximumColumn" Width="180" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="DownloadConnectionRow" Height="0" />
                        <RowDefinition x:Name="DownloadMaximumRow" Height="0" />
                    </Grid.RowDefinitions>
                    <TextBox
                        x:Name="FileNameTextBox"
                        Header="库内文件名"
                        PlaceholderText="package.whl"
                        TextChanged="OnFileNameChanged" />
                    <ComboBox
                        x:Name="ConnectionCountPicker"
                        Grid.Column="1"
                        Header="连接数" />
                    <NumberBox
                        x:Name="MaximumSizeBox"
                        Grid.Column="2"
                        Header="最大大小 (MB)"
                        LargeChange="1024"
                        Maximum="1048576"
                        Minimum="1"
                        SmallChange="128"
                        SpinButtonPlacementMode="Compact"
                        Value="8192" />
                </Grid>

                <ToggleSwitch
                    x:Name="IntegrityToggle"
                    Header="预期摘要"
                    OffContent="未提供，仅计算内容 SHA-256"
                    OnContent="下载完成后必须匹配"
                    Toggled="OnIntegrityToggled" />
                <Grid x:Name="IntegrityFields" ColumnSpacing="12" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="IntegrityPrimaryColumn" Width="180" />
                        <ColumnDefinition x:Name="IntegritySecondaryColumn" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="IntegrityHashRow" Height="0" />
                    </Grid.RowDefinitions>
                    <ComboBox
                        x:Name="HashAlgorithmPicker"
                        Header="算法">
                        <ComboBoxItem Content="SHA-256" Tag="sha256" />
                        <ComboBoxItem Content="SHA-512" Tag="sha512" />
                    </ComboBox>
                    <TextBox
                        x:Name="ExpectedHashTextBox"
                        Grid.Column="1"
                        Header="预期十六进制摘要"
                        PlaceholderText="64 位 SHA-256 或 128 位 SHA-512" />
                </Grid>

                <StackPanel
                    x:Name="TransferActions"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        x:Name="StartDownloadButton"
                        Click="OnStartDownloadClicked"
                        Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Download" />
                            <TextBlock Text="开始下载" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="CancelTransferButton"
                        Click="OnCancelTransferClicked"
                        IsEnabled="False"
                        ToolTipService.ToolTip="取消任务并尝试清理所有未完成分段">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Cancel" />
                            <TextBlock Text="取消" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>

            <Grid
                x:Name="TransferStatusPanel"
                Padding="0,12"
                RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition x:Name="TransferBytesColumn" Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="TransferBytesRow" Height="0" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="TransferTitleText" FontWeight="SemiBold" Text="当前没有任务" />
                    <TextBlock
                        x:Name="TransferBytesText"
                        Grid.Column="1"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>
                <ProgressBar
                    x:Name="TransferProgressBar"
                    Grid.Row="1"
                    Height="4"
                    AutomationProperties.Name="当前受管传输进度" />
                <TextBlock
                    x:Name="TransferDetailText"
                    Grid.Row="2"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    IsTextSelectionEnabled="True"
                    TextWrapping="Wrap" />
            </Grid>

            <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <StackPanel Spacing="12">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="下载库" />
                        <TextBlock
                            x:Name="LibrarySummaryText"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="正在读取…" />
                    </StackPanel>
                    <Button
                        AutomationProperties.Name="刷新下载库"
                        Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Click="OnRefreshLibraryClicked"
                        ToolTipService.ToolTip="重新读取下载库">
                        <SymbolIcon Symbol="Refresh" />
                    </Button>
                </Grid>

                <ListView
                    x:Name="LibraryList"
                    MaxHeight="520"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8,10" ColumnSpacing="12" RowSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition x:Name="LibraryItemActionsColumn" Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition x:Name="LibraryItemActionsRow" Height="0" />
                                </Grid.RowDefinitions>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup>
                                        <VisualState x:Name="CompactLibraryItem">
                                            <VisualState.StateTriggers>
                                                <AdaptiveTrigger MinWindowWidth="0" />
                                            </VisualState.StateTriggers>
                                            <VisualState.Setters>
                                                <Setter Target="LibraryItemActionsColumn.Width" Value="0" />
                                                <Setter Target="LibraryItemActionsRow.Height" Value="Auto" />
                                                <Setter Target="LibraryItemActions.(Grid.Row)" Value="3" />
                                                <Setter Target="LibraryItemActions.(Grid.Column)" Value="0" />
                                                <Setter Target="LibraryItemActions.(Grid.RowSpan)" Value="1" />
                                                <Setter Target="LibraryItemActions.Margin" Value="0,4,0,0" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="WideLibraryItem">
                                            <VisualState.StateTriggers>
                                                <AdaptiveTrigger MinWindowWidth="760" />
                                            </VisualState.StateTriggers>
                                            <VisualState.Setters>
                                                <Setter Target="LibraryItemActionsColumn.Width" Value="Auto" />
                                                <Setter Target="LibraryItemActionsRow.Height" Value="0" />
                                                <Setter Target="LibraryItemActions.(Grid.Row)" Value="0" />
                                                <Setter Target="LibraryItemActions.(Grid.Column)" Value="1" />
                                                <Setter Target="LibraryItemActions.(Grid.RowSpan)" Value="3" />
                                                <Setter Target="LibraryItemActions.Margin" Value="0" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="{Binding FileName}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTipService.ToolTip="{Binding FileName}" />
                                <StackPanel
                                    x:Name="LibraryItemActions"
                                    Grid.Column="1"
                                    Grid.RowSpan="3"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <Button
                                        Click="OnInstallWheelClicked"
                                        Tag="{Binding}"
                                        Visibility="{Binding PipInstallVisibility}"
                                        ToolTipService.ToolTip="安装到 D 盘受管 Python 虚拟环境">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE950;" />
                                            <TextBlock Text="安装" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        AutomationProperties.Name="打开下载文件所在位置"
                                        Click="OnOpenItemFolderClicked"
                                        Tag="{Binding}"
                                        ToolTipService.ToolTip="打开文件所在位置">
                                        <SymbolIcon Symbol="Folder" />
                                    </Button>
                                    <Button
                                        AutomationProperties.Name="从受管下载库删除文件"
                                        Click="OnDeleteLibraryItemClicked"
                                        Tag="{Binding}"
                                        ToolTipService.ToolTip="从受管下载库删除">
                                        <SymbolIcon Symbol="Delete" />
                                    </Button>
                                </StackPanel>
                                <TextBlock
                                    Grid.Row="1"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{Binding Summary}"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Grid.Row="2"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    IsTextSelectionEnabled="True"
                                    Text="{Binding IntegritySummary}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTipService.ToolTip="{Binding IntegritySummary}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
