<Page
    x:Class="AutoEnvPlus.App.Pages.PathPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="{StaticResource PagePadding}" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="PATH 与变量" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="启用后只向用户 PATH 添加一次 AutoEnvPlus Shim；版本切换不会反复重写 PATH。"
                TextWrapping="Wrap" />
            <Button
                x:Name="ActivateShimButton"
                Margin="0,8,0,0"
                HorizontalAlignment="Left"
                Click="OnActivateShimClicked"
                Content="启用命令版本切换" />
        </StackPanel>

        <InfoBar
            x:Name="SummaryInfo"
            Grid.Row="1"
            IsClosable="False"
            IsOpen="True" />

        <ListView
            x:Name="PathList"
            Grid.Row="2"
            IsItemClickEnabled="False"
            SelectionMode="None">
            <ListView.Header>
                <Grid Padding="12,8" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontWeight="SemiBold" Text="顺序" />
                    <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="作用域" />
                    <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="目录" />
                    <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="状态" />
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="12,8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Index}" />
                        <TextBlock Grid.Column="1" Text="{Binding Scope}" />
                        <TextBlock
                            Grid.Column="2"
                            Text="{Binding Path}"
                            TextTrimming="CharacterEllipsis"
                            ToolTipService.ToolTip="{Binding Path}" />
                        <TextBlock Grid.Column="3" Text="{Binding Status}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
