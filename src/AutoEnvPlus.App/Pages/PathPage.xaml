<Page
    x:Class="AutoEnvPlus.App.Pages.PathPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="{StaticResource PagePadding}" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="PATH 与变量" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="启用后只向用户 PATH 添加一次 AutoEnvPlus Shim；版本切换不会反复重写 PATH。"
                TextWrapping="Wrap" />
            <Button
                x:Name="ActivateShimButton"
                Margin="0,8,0,0"
                HorizontalAlignment="Left"
                Click="OnActivateShimClicked"
                Content="启用命令版本切换" />
        </StackPanel>

        <InfoBar
            x:Name="SummaryInfo"
            Grid.Row="1"
            IsClosable="False"
            IsOpen="True" />

        <Grid Grid.Row="2" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="2">
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="PATH 回滚快照" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="仅恢复 AutoEnvPlus 写入前的用户 PATH；系统 PATH 和 Shim 文件保持不变。"
                        TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        x:Name="RefreshSnapshotsButton"
                        Width="36"
                        Height="36"
                        AutomationProperties.Name="刷新 PATH 快照"
                        Click="OnRefreshSnapshotsClicked"
                        ToolTipService.ToolTip="刷新 PATH 快照">
                        <FontIcon FontSize="14" Glyph="&#xE72C;" />
                    </Button>
                    <Button
                        x:Name="RollbackPathButton"
                        MinWidth="124"
                        Height="36"
                        AutomationProperties.Name="回滚用户 PATH"
                        Click="OnRollbackPathClicked"
                        IsEnabled="False">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE7A7;" />
                            <TextBlock Text="回滚用户 PATH" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <TextBlock
                x:Name="SnapshotSummaryText"
                Grid.Row="1"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="正在读取 PATH 快照…"
                TextWrapping="Wrap" />

            <Grid Grid.Row="2">
                <ListView
                    x:Name="SnapshotList"
                    MaxHeight="164"
                    SelectionChanged="OnSnapshotSelectionChanged"
                    SelectionMode="Single"
                    Visibility="Collapsed">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="10,6" ColumnSpacing="12" RowSpacing="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock FontWeight="SemiBold" Text="{Binding CreatedAt}" />
                                <TextBlock Grid.Column="1" Text="{Binding State}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.ColumnSpan="2"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{Binding AddedDirectory}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTipService.ToolTip="{Binding SnapshotPath}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <TextBlock
                    x:Name="SnapshotEmptyText"
                    Padding="10,6"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="尚未创建 PATH 快照。" />
            </Grid>
        </Grid>

        <ListView
            x:Name="PathList"
            Grid.Row="3"
            IsItemClickEnabled="False"
            SelectionMode="None">
            <ListView.Header>
                <Grid Padding="12,8" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontWeight="SemiBold" Text="顺序" />
                    <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="作用域" />
                    <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="目录" />
                    <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="状态" />
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="12,8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Index}" />
                        <TextBlock Grid.Column="1" Text="{Binding Scope}" />
                        <TextBlock
                            Grid.Column="2"
                            Text="{Binding Path}"
                            TextTrimming="CharacterEllipsis"
                            ToolTipService.ToolTip="{Binding Path}" />
                        <TextBlock Grid.Column="3" Text="{Binding Status}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
