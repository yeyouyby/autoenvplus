<Page
    x:Class="AutoEnvPlus.App.Pages.PathPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="{StaticResource PagePadding}" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="PATH 与命令" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="用户 PATH 只配置一次 AutoEnvPlus Shim；后续全局、项目和会话切换不再重写 PATH。"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="ShimStateText"
                    FontWeight="SemiBold"
                    Text="正在读取 Shim 路由状态…"
                    TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Bottom"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    x:Name="RefreshPathButton"
                    Width="36"
                    Height="36"
                    AutomationProperties.Name="刷新 PATH 与命令"
                    Click="OnRefreshPathClicked"
                    ToolTipService.ToolTip="刷新 PATH 与命令">
                    <FontIcon FontSize="14" Glyph="&#xE72C;" />
                </Button>
                <Button
                    x:Name="ActivateShimButton"
                    Click="OnActivateShimClicked">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE73E;" />
                        <TextBlock Text="配置 AutoEnvPlus Shim" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <InfoBar
            x:Name="SummaryInfo"
            Grid.Row="1"
            IsClosable="False"
            IsOpen="True" />

        <ItemsRepeater
            x:Name="SwitchScopeRepeater"
            Grid.Row="2">
            <ItemsRepeater.Layout>
                <UniformGridLayout
                    MinColumnSpacing="20"
                    MinItemWidth="180"
                    MinRowSpacing="8" />
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
                <DataTemplate>
                    <StackPanel Padding="8,4" Spacing="2">
                        <TextBlock FontWeight="SemiBold" Text="{Binding Scope}" />
                        <TextBlock Text="{Binding Priority}" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding Detail}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </DataTemplate>
            </ItemsRepeater.ItemTemplate>
        </ItemsRepeater>

        <Pivot Grid.Row="3">
            <PivotItem Header="命令路由">
                <ListView x:Name="CommandRouteList" SelectionMode="None">
                    <ListView.Header>
                        <Grid Padding="12,8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontWeight="SemiBold" Text="命令" />
                            <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="实际入口" />
                            <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="路由状态" />
                        </Grid>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="150" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontWeight="SemiBold" Text="{Binding Command}" />
                                <TextBlock
                                    Grid.Column="1"
                                    IsTextSelectionEnabled="True"
                                    Text="{Binding Winner}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTipService.ToolTip="{Binding Winner}" />
                                <TextBlock
                                    Grid.Column="2"
                                    Text="{Binding State}"
                                    TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </PivotItem>

            <PivotItem Header="PATH 目录">
                <ListView
                    x:Name="PathList"
                    IsItemClickEnabled="False"
                    SelectionMode="None">
                    <ListView.Header>
                        <Grid Padding="12,8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontWeight="SemiBold" Text="顺序" />
                            <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="作用域" />
                            <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="目录" />
                            <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="状态" />
                        </Grid>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Index}" />
                                <TextBlock Grid.Column="1" Text="{Binding Scope}" />
                                <TextBlock
                                    Grid.Column="2"
                                    Text="{Binding Path}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTipService.ToolTip="{Binding Path}" />
                                <TextBlock Grid.Column="3" Text="{Binding Status}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </PivotItem>

            <PivotItem Header="回滚快照">
                <Grid Padding="0,8,0,0" RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock
                                FontSize="16"
                                FontWeight="SemiBold"
                                Text="用户 PATH 回滚" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="仅恢复 AutoEnvPlus 写入前的用户 PATH；系统 PATH 和 Shim 文件保持不变。"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8">
                            <Button
                                x:Name="RefreshSnapshotsButton"
                                Width="36"
                                Height="36"
                                AutomationProperties.Name="刷新 PATH 快照"
                                Click="OnRefreshSnapshotsClicked"
                                ToolTipService.ToolTip="刷新 PATH 快照">
                                <FontIcon FontSize="14" Glyph="&#xE72C;" />
                            </Button>
                            <Button
                                x:Name="RollbackPathButton"
                                MinWidth="124"
                                Height="36"
                                AutomationProperties.Name="回滚用户 PATH"
                                Click="OnRollbackPathClicked"
                                IsEnabled="False">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="14" Glyph="&#xE7A7;" />
                                    <TextBlock Text="回滚用户 PATH" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <TextBlock
                        x:Name="SnapshotSummaryText"
                        Grid.Row="1"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="正在读取 PATH 快照…"
                        TextWrapping="Wrap" />

                    <Grid Grid.Row="2">
                        <ListView
                            x:Name="SnapshotList"
                            MaxHeight="260"
                            SelectionChanged="OnSnapshotSelectionChanged"
                            SelectionMode="Single"
                            Visibility="Collapsed">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="10,6" ColumnSpacing="12" RowSpacing="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding CreatedAt}" />
                                        <TextBlock Grid.Column="1" Text="{Binding State}" />
                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.ColumnSpan="2"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{Binding AddedDirectory}"
                                            TextTrimming="CharacterEllipsis"
                                            ToolTipService.ToolTip="{Binding SnapshotPath}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBlock
                            x:Name="SnapshotEmptyText"
                            Padding="10,6"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="尚未创建 PATH 快照。" />
                    </Grid>
                </Grid>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
