<Page
    x:Class="AutoEnvPlus.App.Pages.ActivityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="{StaticResource PagePadding}" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="活动记录" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="查看 AutoEnvPlus 的语言工具安装、版本切换、PATH、缓存和项目操作审计。记录仅保存脱敏摘要。"
                    TextWrapping="Wrap" />
            </StackPanel>
            <Button
                x:Name="RefreshButton"
                Grid.Column="1"
                Width="40"
                Height="40"
                AutomationProperties.Name="刷新活动记录"
                Click="OnRefreshClicked"
                ToolTipService.ToolTip="刷新活动记录">
                <FontIcon FontSize="16" Glyph="&#xE72C;" />
            </Button>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="260" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <ComboBox
                x:Name="StatusFilter"
                AutomationProperties.Name="按状态筛选"
                Header="状态"
                SelectionChanged="OnFilterChanged">
                <ComboBoxItem Content="全部状态" />
                <ComboBoxItem Content="成功" />
                <ComboBoxItem Content="失败" />
                <ComboBoxItem Content="已取消" />
            </ComboBox>
            <ComboBox
                x:Name="TypeFilter"
                Grid.Column="1"
                AutomationProperties.Name="按操作类型筛选"
                Header="操作类型"
                SelectionChanged="OnFilterChanged">
                <ComboBoxItem Content="全部操作" />
            </ComboBox>
            <TextBlock
                Grid.Column="2"
                Margin="0,28,0,0"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="回滚和快照路径仅供审计查看；本页不会自动执行回滚。"
                TextWrapping="Wrap" />
        </Grid>

        <InfoBar
            x:Name="ActivityInfo"
            Grid.Row="2"
            IsClosable="False"
            IsOpen="True"
            Severity="Informational" />

        <Grid Grid.Row="3">
            <ListView
                x:Name="ActivityList"
                IsItemClickEnabled="False"
                SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid RowSpacing="6" ColumnSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding OperationText}" />
                                    <TextBlock Text="{Binding StatusText}" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding TimestampText}" />
                                </StackPanel>
                                <Button
                                    Grid.Column="1"
                                    AutomationProperties.Name="复制活动摘要"
                                    Click="OnCopyClicked"
                                    Content="复制摘要"
                                    Tag="{Binding}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.ColumnSpan="2"
                                    IsTextSelectionEnabled="True"
                                    Text="{Binding Summary}"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Grid.Row="2"
                                    Grid.ColumnSpan="2"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    IsTextSelectionEnabled="True"
                                    Text="{Binding AffectedPathsText}"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Grid.Row="3"
                                    Grid.ColumnSpan="2"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    IsTextSelectionEnabled="True"
                                    Text="{Binding SnapshotText}"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Grid.Row="4"
                                    Grid.ColumnSpan="2"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    IsTextSelectionEnabled="True"
                                    Text="{Binding RollbackText}"
                                    TextWrapping="Wrap" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <TextBlock
                x:Name="EmptyText"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="暂无符合筛选条件的活动记录。"
                Visibility="Collapsed" />
        </Grid>
    </Grid>
</Page>
